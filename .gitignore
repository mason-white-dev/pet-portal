# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore Skylight config — it holds the APM auth token (set SKYLIGHT_AUTHENTICATION in prod).
/config/skylight.yml

# Ignore editor and OS files.
/.idea
.DS_Store

# Ignore Claude Code per-session runtime state (e.g. the scheduled-tasks lock,
# which holds a session id/PID and must not be shared across machines).
/.claude/scheduled_tasks.lock

