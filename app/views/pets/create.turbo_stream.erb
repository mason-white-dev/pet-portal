<%#
  # Pet Create — Turbo Stream response (SUCCESS path)
  #
  # Rendered by PetsController#create after a pet is saved. Slots the new pet
  # into the index without a full reload:
  #   1. prepend its card to the gallery (#pets), and
  #   2. refresh the roster subhead (count + drops the empty-state message —
  #      matters most when this is the very first pet).
  # The modal closes itself via popup_controller (turbo:submit-end success).
  #
  # On failure the controller re-renders :new (422) into the drawer frame
  # instead, so that path never reaches this file.
%>
<%# New card goes first; wrapped in .col to match the gallery grid structure. %>
<%= turbo_stream.prepend "pets" do %>
  <div class="col"><%= render "pets/pet_card", pet: @pet %></div>
<% end %>

<%# Refresh the "N companions" line (replaces the whole <p id="pets_subhead">). %>
<%= turbo_stream.replace "pets_subhead", partial: "pets/subhead", locals: { count: current_user.pets.count } %>
