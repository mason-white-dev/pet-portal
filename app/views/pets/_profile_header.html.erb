<%# Horizontal profile header: avatar + identity on the left, tab nav pushed
    to the right, with a divider beneath. Per-section "add" actions live inside
    each tab's content, not here. %>
<div class="d-flex align-items-center flex-wrap gap-4 border-bottom border-secondary-subtle pb-3 mb-4">

  <%# Avatar + identity %>
  <div class="d-flex align-items-center gap-3">
    <% if pet.avatar_image.attached? %>
      <%= image_tag pet.avatar_image, class: "rounded-3 border border-dark object-fit-cover flex-shrink-0", style: "width: 56px; height: 56px;" %>
    <% else %>
      <div class="rounded-3 border border-dark d-flex align-items-center justify-content-center bg-light flex-shrink-0" style="width: 56px; height: 56px; background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.02) 10px, rgba(0,0,0,0.02) 20px);">
        <span class="fw-bold text-secondary pp-handwritten fs-4"><%= pet.name[0].upcase %></span>
      </div>
    <% end %>

    <div class="lh-sm">
      <h1 class="fw-bold mb-0 text-ink h5"><%= pet.name %></h1>
      <div class="text-secondary small">
        <% details = [pet.breed.presence, pet.species&.humanize.presence].compact %>
        <% breed_info = details.join(" • ") %>
        <% if pet.date_of_birth.present? %>
          <% age_info = time_ago_in_words(pet.date_of_birth).gsub("about ", "").gsub(" years", " yr").gsub(" year", " yr") %>
          <%= [breed_info.presence, age_info].compact.join(" • ") %>
        <% else %>
          <%= breed_info %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Tab nav — pushed to the right edge %>
  <div class="ms-auto">
    <%= render "pets/nav_tabs", pet: pet, active_tab: active_tab %>
  </div>
</div>
