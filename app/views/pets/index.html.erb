<%#
  # Pets Index View
  #
  # Primary dashboard: a photo-forward gallery of the user's pets, echoing the
  # landing page's warm/crisp brand (white cards on the off-white canvas, a single
  # coral accent, generous whitespace). Each pet is a card (see pets/_pet_card);
  # a dashed ghost tile closes the grid and doubles as the empty state.
  #
  # Wire Frame Reference:
  # https://github.com/mason-white-dev/pet-portal/blob/main/wireframes/MyPets.png
%>

<% content_for :title, "My Pets" %>

<div class="mx-auto" style="max-width: 1100px;">

  <%# --- PAGE HEADER --- %>
  <div class="d-flex justify-content-between align-items-end mb-4">
    <div>
      <h1 class="fw-bold mb-1 text-ink">My Pets</h1>
      <p class="text-secondary mb-0">
        <%= @pets.any? ? "#{pluralize(@pets.size, "companion")} in your care" : "Let's start your first chart" %>
      </p>
    </div>
    <%= link_to "+ Add pet", new_pet_path, class: "btn bg-ink text-white rounded-pill px-4 py-2 fw-medium shadow-sm" %>
  </div>

  <%# --------------- PETS GALLERY ----------------- %>
  <%# --- Responsive: 1 per row (mobile) / 2 (sm) / 3 (lg) --- %>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4" id="pets">

    <%# --- RENDER PET CARDS --- %>
    <% @pets.each do |pet| %>
      <div class="col">
        <%= render "pets/pet_card", pet: pet %>
      </div>
    <% end %>

    <%# --- GHOST ADD TILE: closes the grid, and is the whole UI when empty --- %>
    <div class="col">
      <%= link_to new_pet_path, class: "pet-card-add card h-100 rounded-4 d-flex align-items-center justify-content-center text-decoration-none text-secondary" do %>
        <div class="text-center p-4">
          <span class="pet-card-add__icon d-inline-flex align-items-center justify-content-center rounded-circle mb-3">
            <i class="fa-solid fa-plus fs-5"></i>
          </span>
          <div class="fw-medium"><%= @pets.any? ? "Add a pet" : "Add your first pet" %></div>
        </div>
      <% end %>
    </div>

  </div>
</div>
