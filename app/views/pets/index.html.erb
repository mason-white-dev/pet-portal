<%#
  # Pets Index View
  #
  # Primary dashboard: a calm, scannable list of the user's pets. Each pet is a
  # horizontal banner row (see pets/_pet_card). Constrained to a comfortable
  # reading width rather than stretching the full main-content area.
  #
  # Wire Frame Reference:
  # https://github.com/mason-white-dev/pet-portal/blob/main/wireframes/MyPets.png
%>

<% content_for :title, "My Pets" %>

<div class="mx-auto" style="max-width: 960px;">

  <%# --- PAGE HEADER --- %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0 text-ink">My Pets</h1>
    <%= link_to "+ Add pet", new_pet_path, class: "btn bg-ink text-white rounded-pill px-4 fw-medium shadow-sm" %>
  </div>

  <%# --- PETS LIST (thin top border + per-row dividers enclose the list) --- %>
  <div id="pets" class="border-top border-secondary-subtle">

    <%# --- RENDER PET ROWS --- %>
    <% @pets.each do |pet| %>
      <%= render "pets/pet_card", pet: pet %>
    <% end %>

    <%# --- EMPTY STATE (NO PETS): keep the row rhythm, prompt to add one --- %>
    <% if @pets.empty? %>
      <%= link_to new_pet_path,
            class: "pet-row d-flex align-items-center gap-3 gap-md-4 py-4 px-2 px-md-3 text-decoration-none text-secondary border-bottom border-secondary-subtle" do %>
        <div class="rounded-3 bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width: 64px; height: 64px;">
          <i class="fa-solid fa-plus"></i>
        </div>
        <div class="fw-medium">Add your first pet</div>
      <% end %>
    <% end %>

  </div>
</div>
