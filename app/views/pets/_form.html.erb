<%#
  # Pet Form (shared by new + edit)
  #
  # Mirrors the merged Identity card (pets/_pet_identity_card): current photo +
  # change control on the LEFT, the editable identity fields on the RIGHT, using
  # the shared `.field-label` style — so the modal reads as "the card, made
  # editable." Rendered inside the modal's "drawer" frame via pets/edit.html.erb.
%>
<%= form_with(model: pet) do |form| %>

  <%# --- ERROR SUMMARY --- %>
  <%# On a failed save the controller re-renders :edit (422), so this lands %>
  <%# back in the drawer frame and the errors show in the still-open modal. %>
  <% if pet.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <div class="fw-bold mb-1"><%= pluralize(pet.errors.count, "error") %> stopped this from saving:</div>
      <ul class="mb-0 ps-3">
        <% pet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-4">

    <%# --- LEFT: current photo + change control (mirrors the card's photo) --- %>
    <%# data-controller wires the live preview: picking a file points the <img> %>
    <%# at a local object URL (no upload until "Save changes" submits). %>
    <div class="col-md-4" data-controller="image-preview">

      <%# Preview <img>. When a photo exists it's shown; when not, a src-less %>
      <%# hidden <img> waits to be filled by the controller on file pick. %>
      <% if pet.avatar_image.attached? %>
        <%= image_tag pet.avatar_image, alt: pet.name,
              class: "w-100 rounded-3 object-fit-cover mb-3",
              style: "aspect-ratio: 1 / 1;",
              data: { image_preview_target: "image" } %>
      <% else %>
        <img alt="" class="w-100 rounded-3 object-fit-cover mb-3 d-none"
             style="aspect-ratio: 1 / 1;"
             data-image-preview-target="image">
      <% end %>

      <%# Hatched placeholder, hidden once a photo exists or is picked. %>
      <div class="w-100 rounded-3 bg-light d-flex align-items-center justify-content-center mb-3 <%= "d-none" if pet.avatar_image.attached? %>"
           style="aspect-ratio: 1 / 1; background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.02) 10px, rgba(0,0,0,0.02) 20px);"
           data-image-preview-target="placeholder">
        <span class="badge bg-white text-secondary border border-secondary-subtle fw-normal">No photo yet</span>
      </div>

      <%# Native file input, hidden — the buttons below drive it. It still %>
      <%# submits the chosen file as pet[avatar_image] on save. %>
      <%= form.file_field :avatar_image, accept: "image/*", class: "d-none",
            data: { image_preview_target: "input", action: "change->image-preview#update" } %>

      <%# "1" here tells PetsController#update to purge the stored photo on save. %>
      <%# It's read directly from params, not via pet_params. %>
      <%= hidden_field_tag "pet[remove_avatar_image]", "",
            data: { image_preview_target: "removeFlag" } %>

      <%# Prettier replacement for the default file UI: a button to open the %>
      <%# picker, and one to clear the photo. The result is shown via the live %>
      <%# preview above, so the file path/name is unnecessary. %>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill flex-grow-1" data-action="image-preview#choose">
          <i class="fa-solid fa-camera me-1"></i> Change photo
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill" data-action="image-preview#remove" title="Remove photo">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    </div>

    <%# --- RIGHT: editable identity fields (mirrors the card's detail grid) --- %>
    <div class="col-md-8">
      <div class="row g-3">

        <div class="col-sm-6">
          <%= form.label :name, class: "field-label" %>
          <%= form.text_field :name, class: "form-control" %>
        </div>

        <div class="col-sm-6">
          <%= form.label :species, class: "field-label" %>
          <%= form.select :species, Pet.species.keys.map { |k| [ k.humanize, k ] }, { prompt: "Select species" }, class: "form-select" %>
        </div>

        <div class="col-sm-6">
          <%= form.label :breed, class: "field-label" %>
          <%= form.text_field :breed, class: "form-control" %>
        </div>

        <div class="col-sm-6">
          <%= form.label :sex, class: "field-label" %>
          <%= form.select :sex, Pet.sexes.keys.map { |k| [ k.humanize, k ] }, { prompt: "Select sex" }, class: "form-select" %>
        </div>

        <div class="col-sm-6">
          <%= form.label :date_of_birth, "Birthday", class: "field-label" %>
          <%= form.date_field :date_of_birth, class: "form-control" %>
        </div>

        <div class="col-sm-6">
          <%= form.label :microchip, class: "field-label" %>
          <%= form.text_field :microchip, class: "form-control" %>
        </div>

        <%# Neutered: boolean, so a checkbox rather than a value --- %>
        <div class="col-12">
          <div class="form-check">
            <%= form.check_box :neutered, class: "form-check-input" %>
            <%= form.label :neutered, class: "form-check-label" %>
          </div>
        </div>

        <div class="col-12">
          <%= form.label :notes, class: "field-label" %>
          <%= form.text_area :notes, rows: 4, class: "form-control" %>
        </div>

      </div>
    </div>

  </div>

  <%# --- ACTIONS: Cancel just dismisses the Bootstrap modal; Save submits --- %>
  <div class="d-flex justify-content-end gap-2 mt-4">
    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
    <%= form.submit "Save changes", class: "btn btn-ink rounded-pill px-4" %>
  </div>

<% end %>
