<%#
  # Pet Form (shared by new + edit)
  #
  # Mirrors the merged Identity card (pets/_pet_identity_card): the photo + change
  # control on the LEFT, the editable identity fields on the RIGHT, using the
  # shared `.field-label` style (with matching coral icons) — so the modal reads
  # as "the card, made editable." Rendered inside the modal's "drawer" frame via
  # pets/new.html.erb and pets/edit.html.erb.
  #
  # Validation errors are shown INLINE, per field: each input gets `is-invalid`
  # (Bootstrap's red border + icon) and a message underneath via the field_error
  # helper — same treatment as the sign-up form, rather than one summary alert.
  #
  # IMPORTANT: the photo column is driven by the `image-preview` Stimulus
  # controller. The data-controller / data-image-preview-target / data-action
  # hooks below are load-bearing — picking a file points the <img> at a local
  # object URL (no upload until submit). Restyle freely, but keep those hooks.
%>
<%= form_with(model: pet) do |form| %>

  <div class="row g-4">

    <%# --- LEFT: current photo + change control (mirrors the card's photo) --- %>
    <div class="col-md-4" data-controller="image-preview">

      <%# A just-uploaded file on an UNSAVED pet (e.g. a validation-error re-render) %>
      <%# is attached but its blob isn't persisted — image_tag can't build a URL for %>
      <%# it ("Cannot get a signed_id for a new record"). So treat it as a real photo %>
      <%# only when the blob is persisted; otherwise fall back to the placeholder. %>
      <% has_photo = pet.avatar_image.attached? && pet.avatar_image.blob&.persisted? %>

      <%# Preview <img>. Shown when there's a saved photo; otherwise a src-less %>
      <%# hidden <img> waits to be filled by the controller on file pick. %>
      <% if has_photo %>
        <%= image_tag pet.avatar_image, alt: pet.name,
              class: "w-100 rounded-4 object-fit-cover shadow-sm mb-3",
              style: "aspect-ratio: 1 / 1;",
              data: { image_preview_target: "image" } %>
      <% else %>
        <img alt="" class="w-100 rounded-4 object-fit-cover shadow-sm mb-3 d-none"
             style="aspect-ratio: 1 / 1;"
             data-image-preview-target="image">
      <% end %>

      <%# Coral monogram placeholder (matches the profile card + gallery), hidden %>
      <%# once a photo exists or is picked. On a brand-new pet with no name yet, %>
      <%# show a neutral camera prompt instead of an initial. %>
      <div class="pet-card__monogram w-100 rounded-4 d-flex flex-column align-items-center justify-content-center mb-3 <%= "d-none" if has_photo %>"
           style="aspect-ratio: 1 / 1;"
           data-image-preview-target="placeholder">
        <% if pet.name.present? %>
          <span class="display-3 fw-bold"><%= pet.name.to_s.first.upcase %></span>
        <% else %>
          <i class="fa-solid fa-camera fs-1 mb-2"></i>
          <span class="small fw-medium">Add a photo</span>
        <% end %>
      </div>

      <%# Native file input, hidden — the buttons below drive it. It still %>
      <%# submits the chosen file as pet[avatar_image] on save. %>
      <%= form.file_field :avatar_image, accept: "image/*", class: "d-none",
            data: { image_preview_target: "input", action: "change->image-preview#update" } %>

      <%# "1" here tells PetsController#update to purge the stored photo on save. %>
      <%# It's read directly from params, not via pet_params. %>
      <%= hidden_field_tag "pet[remove_avatar_image]", "",
            data: { image_preview_target: "removeFlag" } %>

      <%# Prettier replacement for the default file UI: a button to open the %>
      <%# picker, and one to clear the photo. The result is shown via the live %>
      <%# preview above, so the file path/name is unnecessary. %>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill flex-grow-1" data-action="image-preview#choose">
          <i class="fa-solid fa-camera me-1"></i> Change photo
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill" data-action="image-preview#remove" title="Remove photo">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
      <%# avatar_image errors (wrong type / too large) surface here, under the buttons. %>
      <%= field_error pet, :avatar_image %>
    </div>

    <%# --- RIGHT: editable identity fields (mirrors the card's detail grid) --- %>
    <div class="col-md-8">
      <div class="row g-3">

        <div class="col-sm-6">
          <%= form.label :name, class: "field-label" do %>
            <i class="fa-solid fa-tag text-accent me-1"></i>Name
          <% end %>
          <%= form.text_field :name, placeholder: "e.g. Scout", class: [ "form-control", ("is-invalid" if pet.errors[:name].any?) ] %>
          <%= field_error pet, :name %>
        </div>

        <div class="col-sm-6">
          <%= form.label :species, class: "field-label" do %>
            <i class="fa-solid fa-paw text-accent me-1"></i>Species
          <% end %>
          <%= form.select :species, Pet.species.keys.map { |k| [ k.humanize, k ] }, { prompt: "Select species" }, class: [ "form-select", ("is-invalid" if pet.errors[:species].any?) ] %>
          <%= field_error pet, :species %>
        </div>

        <div class="col-sm-6">
          <%= form.label :breed, class: "field-label" do %>
            <i class="fa-solid fa-dog text-accent me-1"></i>Breed
          <% end %>
          <%= form.text_field :breed, placeholder: "e.g. Mixed Breed", class: [ "form-control", ("is-invalid" if pet.errors[:breed].any?) ] %>
          <%= field_error pet, :breed %>
        </div>

        <div class="col-sm-6">
          <%= form.label :sex, class: "field-label" do %>
            <i class="fa-solid fa-venus-mars text-accent me-1"></i>Sex
          <% end %>
          <%= form.select :sex, Pet.sexes.keys.map { |k| [ k.humanize, k ] }, { prompt: "Select sex" }, class: [ "form-select", ("is-invalid" if pet.errors[:sex].any?) ] %>
          <%= field_error pet, :sex %>
        </div>

        <div class="col-sm-6">
          <%= form.label :date_of_birth, class: "field-label" do %>
            <i class="fa-solid fa-cake-candles text-accent me-1"></i>Birthday
          <% end %>
          <%= form.date_field :date_of_birth, class: [ "form-control", ("is-invalid" if pet.errors[:date_of_birth].any?) ] %>
          <%= field_error pet, :date_of_birth %>
        </div>

        <div class="col-sm-6">
          <%= form.label :microchip, class: "field-label" do %>
            <i class="fa-solid fa-microchip text-accent me-1"></i>Microchip
          <% end %>
          <%= form.text_field :microchip, placeholder: "e.g. Tag-12345", class: [ "form-control", ("is-invalid" if pet.errors[:microchip].any?) ] %>
          <%= field_error pet, :microchip %>
        </div>

        <%# Neutered: matches the other fields — a coral-icon field-label header
            with the control beneath. The control is a plain inline Bootstrap
            switch (no box; a bordered well would make a toggle look like a text
            input). Canonical form-check/form-switch markup so Bootstrap handles
            layout. %>
        <div class="col-sm-6">
          <div class="field-label"><i class="fa-solid fa-scissors text-accent me-1"></i>Spayed / neutered</div>
          <div class="form-check form-switch">
            <%= form.check_box :neutered, class: "form-check-input", role: "switch" %>
            <%= form.label :neutered, "Yes", class: "form-check-label text-ink" %>
          </div>
        </div>

        <div class="col-12">
          <%= form.label :notes, class: "field-label" do %>
            <i class="fa-solid fa-note-sticky text-accent me-1"></i>Notes
          <% end %>
          <%= form.text_area :notes, rows: 4, placeholder: "Anything worth remembering — temperament, allergies, routines…", class: [ "form-control", ("is-invalid" if pet.errors[:notes].any?) ] %>
          <%= field_error pet, :notes %>
        </div>

      </div>
    </div>

  </div>

  <%# --- ACTIONS: divided off; Cancel dismisses the modal, Save submits --- %>
  <div class="d-flex justify-content-end gap-2 border-top border-secondary-subtle mt-4 pt-3">
    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
    <%= form.submit "Save changes", class: "btn btn-ink rounded-pill px-4" %>
  </div>

<% end %>
