<%= link_to pet_path(pet), id: dom_id(pet), class: "card h-100 shadow-sm border border-secondary-subtle rounded-3 text-ink text-decoration-none" do %>
  <div class="card-body p-4">
    <div class="d-flex align-items-center gap-3">
      
      <%# Profile Image / Stub %>
      <% if pet.avatar_image.attached? %>
        <%= image_tag pet.avatar_image, class: "rounded-circle border border-secondary-subtle object-fit-cover", style: "width: 72px; height: 72px; flex-shrink: 0;" %>
      <% else %>
        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border border-secondary-subtle" style="width: 72px; height: 72px; flex-shrink: 0;">
          <span class="fs-4 fw-bold text-secondary pp-handwritten"><%= pet.name.present? ? pet.name[0].upcase : "?" %></span>
        </div>
      <% end %>
      
      <div>
        <h4 class="fw-bold mb-1"><%= pet.name %></h4>
        <div class="text-secondary" style="font-size: 0.95rem;">
          <% details = [pet.breed.presence, pet.species&.humanize.presence].compact %>
          <%= details.join(" • ") %>
          
          <% if pet.date_of_birth.present? %>
            <br>
            <span class="text-muted small">
              <%= time_ago_in_words(pet.date_of_birth).gsub("about ", "").gsub(" years", " yr").gsub(" year", " yr") %> old
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
