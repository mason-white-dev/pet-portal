<%# Horizontal tab nav. Active tab = bold ink text + an underline that sits on
    the header's divider (.pet-tab, see application.css); the rest are muted.
    About → show; the middle tabs are placeholders pending #3–#6. %>
<div class="d-flex align-items-end flex-wrap gap-5">
  <%= link_to pet_path(pet), class: "pet-tab text-decoration-none #{active_tab == :about ? 'active fw-bold text-ink' : 'text-secondary'}", aria: { current: (active_tab == :about ? "page" : nil) } do %>
    About
  <% end %>
  <a href="#" class="pet-tab text-decoration-none text-secondary">Vaccines</a>
  <a href="#" class="pet-tab text-decoration-none text-secondary">Issues &amp; visits</a>
  <a href="#" class="pet-tab text-decoration-none text-secondary">Daily care</a>
  <a href="#" class="pet-tab text-decoration-none text-secondary">Memories</a>
</div>
