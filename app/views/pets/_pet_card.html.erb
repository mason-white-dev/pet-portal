<%#
  # Pet Card (gallery tile)
  #
  # One pet as a photo-forward card for the My Pets gallery: a square cover photo
  # (or a warm monogram fallback when there's no photo yet) above a footer with the
  # name, one-line subtitle, and a coral "go" button. The whole tile links to the
  # pet's profile; the hover lift + button animation live in `.pet-card` /
  # `.pet-card__go` (application.css).
%>
<%= link_to pet_path(pet), id: dom_id(pet),
      class: "pet-card card h-100 border-0 rounded-4 overflow-hidden text-ink text-decoration-none shadow-sm" do %>

  <%# --- Cover photo (square crop keeps mismatched source photos reading as a set) --- %>
  <div class="position-relative overflow-hidden bg-light" style="aspect-ratio: 1 / 1;">
    <% if pet.avatar_image.attached? %>
      <%= image_tag pet.avatar_image, alt: pet.name,
            class: "position-absolute top-0 start-0 w-100 h-100 object-fit-cover" %>
    <% else %>
      <%# --- No photo yet: warm monogram tile rather than an empty frame --- %>
      <div class="pet-card__monogram d-flex align-items-center justify-content-center w-100 h-100">
        <span class="display-4 fw-bold"><%= pet.name.to_s.first&.upcase %></span>
      </div>
    <% end %>
  </div>

  <%# --- Footer: name + subtitle, with a coral "go" affordance --- %>
  <div class="card-body bg-white d-flex align-items-center gap-3 py-3 px-4">
    <div class="flex-grow-1" style="min-width: 0;">
      <div class="fw-bold fs-5 text-truncate mb-0"><%= pet.name %></div>
      <div class="text-secondary small text-truncate"><%= pet_subtitle(pet) %></div>
    </div>
    <span class="pet-card__go d-flex align-items-center justify-content-center rounded-circle flex-shrink-0">
      <i class="fa-solid fa-arrow-right"></i>
    </span>
  </div>
<% end %>
