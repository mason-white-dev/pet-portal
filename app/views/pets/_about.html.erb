<div class="row g-4">
  <%# Left Column — Identity + Notes %>
  <div class="col-lg-6">

    <%# Identity Card %>
    <div class="card shadow-sm border border-secondary-subtle rounded-4 mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-0 px-4">
        <div class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Identity</div>
        <%= link_to "Edit &rarr;".html_safe, edit_pet_path(pet), class: "text-secondary text-decoration-none small", data: { turbo_frame: "_top" } %>
      </div>
      <div class="card-body p-4">

        <div class="row mb-3 border-bottom border-light pb-3">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Name</div>
          <div class="col-8 fw-medium text-ink"><%= pet.name %></div>
        </div>

        <div class="row mb-3 border-bottom border-light pb-3">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Species</div>
          <div class="col-8 fw-medium text-ink"><%= pet.species&.humanize || "—" %></div>
        </div>

        <div class="row mb-3 border-bottom border-light pb-3">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Breed</div>
          <div class="col-8 fw-medium text-ink"><%= pet.breed.presence || "—" %></div>
        </div>

        <div class="row mb-3 border-bottom border-light pb-3">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Sex</div>
          <div class="col-8 fw-medium text-ink">
            <%= pet.sex&.humanize || "—" %>
            <% if pet.neutered %>
              <span class="text-secondary">· <%= pet.sex == "female" ? "spayed" : "neutered" %></span>
            <% end %>
          </div>
        </div>

        <div class="row mb-3 border-bottom border-light pb-3">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Birthday</div>
          <div class="col-8 fw-medium text-ink">
            <% if pet.date_of_birth.present? %>
              <%= pet.date_of_birth.strftime("%B %-d, %Y") %>
              <span class="text-secondary">(<%= time_ago_in_words(pet.date_of_birth) %>)</span>
            <% else %>
              —
            <% end %>
          </div>
        </div>

        <div class="row">
          <div class="col-4 text-muted text-uppercase small" style="letter-spacing: 0.5px;">Microchip</div>
          <div class="col-8 fw-medium text-ink d-flex align-items-center gap-2">
            <%= pet.microchip.presence || "—" %>
            <% if pet.microchip.present? %>
              <span class="badge bg-light text-secondary border border-secondary-subtle fw-normal">registered</span>
            <% end %>
          </div>
        </div>

      </div>
    </div>

    <%# Notes Card %>
    <div class="card shadow-sm border border-secondary-subtle rounded-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-0 px-4">
        <div class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Notes</div>
        <%= link_to "Edit &rarr;".html_safe, edit_pet_path(pet), class: "text-secondary text-decoration-none small", data: { turbo_frame: "_top" } %>
      </div>
      <div class="card-body p-4 pt-3">
        <% if pet.notes.present? %>
          <div class="text-ink" style="line-height: 1.6;">
            <%= simple_format pet.notes %>
          </div>
        <% else %>
          <div class="text-muted fst-italic">No notes recorded yet.</div>
        <% end %>
      </div>
    </div>

  </div>

  <%# Right Column — Daily Schedule + Care Team %>
  <%# Placeholders for now: Daily Schedule comes from Daily Care (#5); %>
  <%# Care Team isn't modeled yet. Honest "coming soon" stubs, no fake data. %>
  <div class="col-lg-6">

    <%# Daily Schedule (placeholder) %>
    <div class="card shadow-sm border border-secondary-subtle rounded-4 mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-0 px-4">
        <div class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Daily Schedule</div>
        <span class="badge bg-light text-secondary border border-secondary-subtle fw-normal">Coming soon</span>
      </div>
      <div class="card-body p-4 pt-3">
        <div class="text-muted fst-italic">Walks, meals, meds, and grooming routines will show up here once Daily Care is set up.</div>
      </div>
    </div>

    <%# Care Team (placeholder) %>
    <div class="card shadow-sm border border-secondary-subtle rounded-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-0 px-4">
        <div class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Care Team</div>
        <span class="badge bg-light text-secondary border border-secondary-subtle fw-normal">Coming soon</span>
      </div>
      <div class="card-body p-4 pt-3">
        <div class="text-muted fst-italic">Vets, groomers, and sitters will live here.</div>
      </div>
    </div>

  </div>
</div>
