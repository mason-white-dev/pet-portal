<%#
  # Pet Profile: "About" Tab
  #
  # The main dashboard for a single pet — a bird's-eye view of identity, daily
  # schedule, and care team.
  #
  # Layout:
  # - Row 1: Identity card (photo + core attributes) and a Daily Schedule preview.
  # - Row 2: the Care Team list (vets, groomers, sitters, etc.).
  #
  # All cards share one visual language: hairline border, soft shadow, rounded-4,
  # a small uppercase "eyebrow" header, and a go-link action on the right.
  #
  # Note: Daily Schedule is a placeholder stub for a future feature; Care Team is
  # live. The Care Team card's HEADER lives here, but its BODY is the
  # care_team_members/list partial (which carries the Turbo Stream target id), so
  # create/update/destroy can refresh just the list without redrawing the header.
%>
<%# --- ROW 1: IDENTITY & DAILY SCHEDULE --- %>
<div class="row g-4 mb-4">
  <%# --- _pet_identity_card.html.erb (col-lg-8 lives on the partial root) --- %>
  <%= render "pet_identity_card", pet: pet %>

  <%# --- DAILY SCHEDULE CARD (PLACEHOLDER) --- %>
  <%# Will display data from the future Daily Care feature %>
  <div class="col-lg-4">
    <div class="card border border-secondary-subtle rounded-4 shadow-sm h-100">
      <div class="card-body p-4 d-flex flex-column">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Daily Schedule</span>
          <span class="badge rounded-pill text-bg-light border border-secondary-subtle fw-normal">Coming soon</span>
        </div>
        <%# Centered empty state so the placeholder reads as intentional. %>
        <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center py-4">
          <span class="pet-card-add__icon d-inline-flex align-items-center justify-content-center rounded-circle mb-3">
            <i class="fa-regular fa-clock fs-4 text-secondary"></i>
          </span>
          <div class="text-muted small px-2">Food, walks, meals, and meds will show up here once Daily Care is set up.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# --- ROW 2: CARE TEAM --- %>
<div class="row g-4">
  <div class="col-12">
    <div class="card border border-secondary-subtle rounded-4 shadow-sm">
      <%# Card HEADER (stays put across Turbo refreshes). "+ Add" and each row's
          "Edit" open the shared drawer modal. %>
      <div class="d-flex justify-content-between align-items-center px-4 pt-4 pb-3">
        <span class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Care Team</span>
        <%= link_to new_pet_care_team_member_path(pet), class: "go-link text-secondary text-decoration-none small fw-medium d-inline-flex align-items-center gap-1", data: { turbo_frame: "drawer" } do %>
          <i class="fa-solid fa-plus"></i> Add
        <% end %>
      </div>
      <%# Card BODY: the list partial (carries the Turbo Stream target id). %>
      <%= render "care_team_members/list", pet: pet %>
    </div>
  </div>
</div>
