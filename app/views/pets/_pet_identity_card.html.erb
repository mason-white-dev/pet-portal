<%#
  # Identity Card (partial)
  #
  # The pet's profile photo + core attributes (name, species, breed, sex,
  # birthday, microchip, notes), shown on the About tab as ONE card: the photo
  # flush on the left, the identity details on the right. Rendered in two
  # places, on purpose:
  #   1. initial page load, from pets/_about, and
  #   2. after a successful edit, from pets/update.turbo_stream.erb.
  # Keeping it in one partial means both paths render identical HTML — and now
  # that the photo lives here too, editing the avatar refreshes live as well.
  #
  # The root <div>'s id is the Turbo Stream REPLACE target. dom_id(pet,
  # :pet_identity_card) → "pet_identity_card_pet_42". This MUST match the
  # dom_id used in update.turbo_stream.erb, or the post-save refresh silently
  # does nothing (Turbo can't find the element to replace).
%>
<%# --- ROOT: id here is what the Turbo Stream replaces after a save --- %>
<div id="<%= dom_id(pet, :pet_identity_card) %>" class="col-lg-8">
  <div class="card shadow-sm border border-secondary-subtle rounded-4 h-100 overflow-hidden">
    <%# row g-0 = zero gutters, so the photo and details sit flush as one card. %>
    <%# overflow-hidden on the card clips the image to the rounded corners.    %>
    <div class="row g-0 h-100">
      <%# --- LEFT: profile photo, filling the card edge-to-edge --- %>
      <div class="col-md-4">
        <% if pet.avatar_image.attached? %>
          <%= image_tag pet.avatar_image, alt: pet.name, class: "w-100 h-100 object-fit-cover" %>
        <% else %>
          <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light" style="min-height: 240px; background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.02) 10px, rgba(0,0,0,0.02) 20px);">
            <span class="badge bg-white text-secondary border border-secondary-subtle fw-normal"><%= pet.name %></span>
          </div>
        <% end %>
      </div>
      <%# --- RIGHT: identity header + fields --- %>
      <div class="col-md-8">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-0 px-4">
          <div class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Identity</div>
          <%# --- EDIT TRIGGER --- %>
          <%# data-turbo-frame: "drawer" redirects this click AWAY from the %>
          <%# pet_content frame this link sits inside, and into the modal's %>
          <%# "drawer" frame instead. Without it, Turbo would try to load the %>
          <%# edit response into pet_content (the whole profile) and fail. %>
          <%= link_to "Edit &rarr;".html_safe, edit_pet_path(pet), class: "text-secondary text-decoration-none small", data: { turbo_frame: "drawer" } %>
        </div>
        <div class="card-body p-4">
          <div class="row g-4">
            <div class="col-sm-6">
              <div class="field-label">Name</div>
              <div class="fw-medium text-ink"><%= pet.name %></div>
            </div>
            <div class="col-sm-6">
              <div class="field-label">Species</div>
              <div class="fw-medium text-ink"><%= pet.species&.humanize || "—" %></div>
            </div>
            <div class="col-sm-6">
              <div class="field-label">Breed</div>
              <div class="fw-medium text-ink"><%= pet.breed.presence || "—" %></div>
            </div>
            <div class="col-sm-6">
              <div class="field-label">Sex</div>
              <div class="fw-medium text-ink">
                <%= pet.sex&.humanize || "—" %>
                <% if pet.neutered %>
                  <span class="text-secondary">· <%= pet.sex == "female" ? "spayed" : "neutered" %></span>
                <% end %>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="field-label">Birthday</div>
              <div class="fw-medium text-ink">
                <% if pet.date_of_birth.present? %>
                  <%= pet.date_of_birth.strftime("%B %-d, %Y") %>
                  <span class="text-secondary d-block">(<%= time_ago_in_words(pet.date_of_birth) %>)</span>
                <% else %>
                  —
                <% end %>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="field-label">Microchip</div>
              <div class="fw-medium text-ink">
                <%= pet.microchip.presence || "—" %>
                <% if pet.microchip.present? %>
                  <span class="badge bg-light text-secondary border border-secondary-subtle fw-normal d-inline-block mt-1">registered</span>
                <% end %>
              </div>
            </div>
            <div class="col-sm-12">
              <div class="field-label">Notes</div>
              <div class="fw-medium text-ink">
                <% if pet.notes.present? %>
                  <div class="text-ink" style="line-height: 1.6;"><%= simple_format pet.notes %></div>
                <% else %>
                  <div class="text-muted fst-italic">No notes recorded yet.</div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
