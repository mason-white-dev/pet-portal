<%#
  # Identity Card (partial)
  #
  # The pet's profile photo + core attributes (name, species, breed, sex,
  # birthday, microchip, notes), shown on the About tab as ONE card: a contained
  # avatar tile on the left, a clean two-column field grid on the right, with the
  # free-text Notes spanning full width beneath. Rendered in two places, on
  # purpose:
  #   1. initial page load, from pets/_about, and
  #   2. after a successful edit, from pets/update.turbo_stream.erb.
  # Keeping it in one partial means both paths render identical HTML — and since
  # the photo lives here too, editing the avatar refreshes live as well.
  #
  # The root <div>'s id is the Turbo Stream REPLACE target. dom_id(pet,
  # :pet_identity_card) → "pet_identity_card_pet_42". This MUST match the
  # dom_id used in update.turbo_stream.erb, or the post-save refresh silently
  # does nothing (Turbo can't find the element to replace).
%>
<%# --- ROOT: id here is what the Turbo Stream replaces after a save --- %>
<div id="<%= dom_id(pet, :pet_identity_card) %>" class="col-lg-8">
  <div class="card border border-secondary-subtle rounded-4 shadow-sm h-100">
    <div class="card-body p-4 p-md-4">

      <%# --- HEADER: section eyebrow + edit trigger --- %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <span class="text-uppercase text-muted fw-bold small" style="letter-spacing: 1px;">Identity</span>
        <%# data-turbo-frame: "drawer" redirects this click AWAY from the
            pet_content frame this link sits inside, and into the modal's "drawer"
            frame instead. Without it, Turbo would try to load the edit response
            into pet_content (the whole profile) and fail. %>
        <%= link_to edit_pet_path(pet), class: "go-link text-secondary text-decoration-none small fw-medium d-inline-flex align-items-center gap-1", data: { turbo_frame: "drawer" } do %>
          Edit <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <%# --- BODY: avatar tile + field grid, stacking on phones --- %>
      <div class="d-flex flex-column flex-sm-row gap-4">

        <%# Contained, rounded avatar with a fixed width. align-self-stretch makes
            it fill the full height of the field grid beside it (the fields set
            the card height); the image fills via w-100 h-100 + object-fit-cover.
            min-height keeps it a clean square on phones, where the columns stack
            and there's no sibling to stretch against. Monogram fallback reuses
            the gallery's coral wash when there's no photo yet. %>
        <div class="flex-shrink-0 align-self-stretch mx-auto mx-sm-0" style="width: 200px;">
          <% if pet.avatar_image.attached? %>
            <%= image_tag pet.avatar_image, alt: pet.name, class: "rounded-4 object-fit-cover shadow-sm w-100 h-100", style: "min-height: 200px;" %>
          <% else %>
            <div class="pet-card__monogram rounded-4 d-flex align-items-center justify-content-center w-100 h-100" style="min-height: 200px;">
              <span class="display-4 fw-bold"><%= pet.name.to_s.first&.upcase %></span>
            </div>
          <% end %>
        </div>

        <%# Field grid: small uppercase labels (field-label) with a coral icon,
            value beneath. Two-up on all but the narrowest cells; Notes is full
            width. %>
        <div class="flex-grow-1" style="min-width: 0;">
          <div class="row g-3 g-md-4">
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-tag text-accent me-1"></i>Name</div>
              <div class="fw-medium text-ink text-truncate"><%= pet.name %></div>
            </div>
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-paw text-accent me-1"></i>Species</div>
              <div class="fw-medium text-ink"><%= pet.species&.humanize || "—" %></div>
            </div>
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-dog text-accent me-1"></i>Breed</div>
              <div class="fw-medium text-ink"><%= pet.breed.presence || "—" %></div>
            </div>
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-venus-mars text-accent me-1"></i>Sex</div>
              <div class="fw-medium text-ink">
                <%= pet.sex&.humanize || "—" %>
                <% if pet.neutered %>
                  <span class="text-secondary">· <%= pet.sex == "female" ? "spayed" : "neutered" %></span>
                <% end %>
              </div>
            </div>
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-cake-candles text-accent me-1"></i>Birthday</div>
              <div class="fw-medium text-ink">
                <% if pet.date_of_birth.present? %>
                  <%= pet.date_of_birth.strftime("%B %-d, %Y") %>
                  <span class="text-secondary d-block small">(<%= time_ago_in_words(pet.date_of_birth) %>)</span>
                <% else %>
                  —
                <% end %>
              </div>
            </div>
            <div class="col-6">
              <div class="field-label"><i class="fa-solid fa-microchip text-accent me-1"></i>Microchip</div>
              <div class="fw-medium text-ink">
                <%= pet.microchip.presence || "—" %>
                <% if pet.microchip.present? %>
                  <span class="badge text-bg-light border border-secondary-subtle fw-normal d-inline-block mt-1">registered</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# --- NOTES: full width, divided off from the grid above --- %>
      <div class="border-top border-secondary-subtle mt-4 pt-4">
        <div class="field-label"><i class="fa-solid fa-note-sticky text-accent me-1"></i>Notes</div>
        <% if pet.notes.present? %>
          <div class="text-ink" style="line-height: 1.6;"><%= simple_format pet.notes %></div>
        <% else %>
          <div class="text-muted fst-italic">No notes recorded yet.</div>
        <% end %>
      </div>

    </div>
  </div>
</div>
