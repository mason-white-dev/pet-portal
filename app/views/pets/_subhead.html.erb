<%#
  # Roster subhead (the line under "My Pets")
  #
  # Its own partial + stable id so create.turbo_stream.erb can replace it when a
  # pet is added — refreshing the count and dropping the empty-state message.
  # `count` is the number of pets the user has.
%>
<p id="pets_subhead" class="text-secondary mb-0">
  <%= count.positive? ? "#{pluralize(count, "companion")} in your care" : "Let's start your first chart" %>
</p>
