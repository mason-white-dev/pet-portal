<%#
  # Care Team list (the card body on the pet profile)
  #
  # The single source of truth for how the care team renders. Drawn directly by
  # pets/_about on first load, and re-rendered by list.turbo_stream.erb after any
  # create/update/destroy. Its root carries dom_id(pet, :care_team_members) — the
  # target the stream replaces. Needs a `pet` local.
  #
  # Members render as a flush list-group of rows (see _care_team_member) so the
  # card reads as one clean, scannable roster. p-0 lets the rows sit edge-to-edge
  # under the header; the empty state gets its own padding.
%>
<div id="<%= dom_id(pet, :care_team_members) %>" class="card-body p-0">
  <% members = pet.care_team_members.ordered.to_a %>
  <% if members.any? %>
    <div class="list-group list-group-flush">
      <%= render partial: "care_team_members/care_team_member", collection: members, locals: { pet: pet } %>
    </div>
  <% else %>
    <%# Empty state: a quiet prompt that matches the placeholder cards' tone. %>
    <div class="text-center text-muted py-5 px-4">
      <span class="pet-card-add__icon d-inline-flex align-items-center justify-content-center rounded-circle mb-3">
        <i class="fa-solid fa-user-group fs-5 text-secondary"></i>
      </span>
      <div class="small">No care team members yet. Add a vet, groomer, sitter, and more.</div>
    </div>
  <% end %>
</div>
