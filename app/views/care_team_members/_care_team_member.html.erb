<%#
  # Care Team Member card (one tile in the Care Team grid on the pet profile)
  #
  # Rendered as a collection from care_team_members/_index
  # (`collection: pet.care_team_members`), so each iteration receives a
  # `care_team_member` local; `pet` is passed through for the edit link's nested
  # path. The root <div class="col"> is the grid cell — the responsive
  # row-cols-* wrapper that arranges these tiles lives in _index.
  #
  # "Edit" opens the shared drawer modal (data-turbo-frame: "drawer").
%>
<div class="col">
  <div class="card h-100 border border-secondary-subtle rounded-3">
    <div class="card-body p-3 d-flex flex-column">
      <%# Top row: role label + edit affordance %>
      <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
        <span class="text-uppercase text-muted fw-bold" style="letter-spacing: 1px; font-size: .7rem;"><%= care_team_member.role_label %></span>
        <%= link_to edit_pet_care_team_member_path(pet, care_team_member), class: "go-link text-secondary text-decoration-none small fw-medium", data: { turbo_frame: "drawer" } do %>
          Edit
        <% end %>
      </div>

      <%# Name + the person to contact %>
      <div class="fw-bold"><%= care_team_member.name %></div>
      <% if care_team_member.contact_name.present? %>
        <div class="text-muted small"><%= care_team_member.contact_name %></div>
      <% end %>

      <%# Contact details %>
      <% if care_team_member.phone.present? || care_team_member.email.present? %>
        <div class="small mt-2">
          <% if care_team_member.phone.present? %>
            <%# tel: href is digits-only (+ kept) so dialers parse it; the label stays formatted. %>
            <div class="text-break"><%= link_to care_team_member.phone, "tel:#{care_team_member.phone.gsub(/[^0-9+]/, "")}", class: "text-decoration-none" %></div>
          <% end %>
          <% if care_team_member.email.present? %>
            <div class="text-break"><%= mail_to care_team_member.email, class: "text-decoration-none" %></div>
          <% end %>
        </div>
      <% end %>

      <% if care_team_member.notes.present? %>
        <div class="text-muted small mt-2"><%= care_team_member.notes %></div>
      <% end %>
    </div>
  </div>
</div>
