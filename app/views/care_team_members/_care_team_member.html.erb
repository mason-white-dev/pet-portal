<%#
  # Care Team Member card (one tile in the Care Team grid on the pet profile)
  #
  # Rendered as a collection from care_team_members/_list
  # (`collection: pet.care_team_members`), so each iteration receives a
  # `care_team_member` local; `pet` is passed through for the edit link's nested
  # path. The root <div class="col"> is the grid cell — the responsive
  # row-cols-* wrapper that arranges these tiles lives in _list.
  #
  # Header is a role "eyebrow" + Edit link; the fields below are compact inline
  # "Label: value" rows (one line each, em dash for blanks) to keep the card
  # short. "Edit" opens the shared drawer modal.
%>
<div class="col">
  <div class="card h-100 border border-secondary-subtle rounded-3">
    <div class="card-body p-3">

      <%# Header: role eyebrow + edit (same layout as the Identity card header) %>
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="text-uppercase text-muted fw-bold" style="letter-spacing: 1px; font-size: .7rem;"><%= care_team_member.role_label %></span>
        <%= link_to edit_pet_care_team_member_path(pet, care_team_member), class: "go-link text-secondary text-decoration-none small fw-medium d-inline-flex align-items-center gap-1", data: { turbo_frame: "drawer" } do %>
          Edit <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <%# Compact inline labeled fields: "Name: Scout" on one line each. %>
      <div class="d-flex flex-column gap-1 small">
        <div>
          <span class="text-muted">Name:</span>
          <span class="fw-medium text-ink"><%= care_team_member.name %></span>
        </div>
        <div>
          <span class="text-muted">Organization:</span>
          <span class="fw-medium text-ink"><%= care_team_member.organization.presence || "—" %></span>
        </div>
        <div>
          <span class="text-muted">Phone:</span>
          <% if care_team_member.phone.present? %>
            <%# tel: href is digits-only (+ kept) so dialers parse it; the label stays formatted. %>
            <%= link_to care_team_member.phone, "tel:#{care_team_member.phone.gsub(/[^0-9+]/, "")}", class: "fw-medium text-decoration-none" %>
          <% else %>
            <span class="fw-medium text-ink">—</span>
          <% end %>
        </div>
        <div class="text-break">
          <span class="text-muted">Email:</span>
          <% if care_team_member.email.present? %>
            <%= mail_to care_team_member.email, class: "fw-medium text-decoration-none" %>
          <% else %>
            <span class="fw-medium text-ink">—</span>
          <% end %>
        </div>
        <div>
          <span class="text-muted">Notes:</span>
          <span class="fw-medium text-ink"><%= care_team_member.notes.presence || "—" %></span>
        </div>
      </div>

    </div>
  </div>
</div>
