<%#
  # Care Team Member form (shared by new + edit)
  #
  # Styled to match pets/_form so the modal reads like the Care Team cards "made
  # editable": a `row g-3` field grid, the shared `.field-label` style, and
  # INLINE per-field validation (each input gets `is-invalid`, with the message
  # rendered underneath by the field_error helper) rather than one summary alert.
  #
  # Fully local-driven: needs `pet` and `care_team_member` locals (passed from
  # new.html.erb / edit.html.erb). Rendered inside the modal's "drawer" frame.
%>
<%# Password managers (1Password, LastPass) mistake non-credential fields like
    "Name"/"Email" for account fields. The `pm_off` helper (application_helper)
    adds the opt-out attributes per FIELD — they only reliably suppress the
    "save to 1Password?" prompt on the input itself, not on the <form>. So every
    field below is wrapped in pm_off(...). %>
<%= form_with(model: [ pet, care_team_member ]) do |form| %>

  <div class="row g-3">

    <div class="col-sm-6">
      <%= form.label :role, class: "field-label" %>
      <%= form.select :role, CareTeamMember.roles.keys.map { |k| [ k.titleize, k ] }, { prompt: "Select a role" }, **pm_off(class: [ "form-select", ("is-invalid" if care_team_member.errors[:role].any?) ]) %>
      <%= field_error care_team_member, :role %>
    </div>

    <div class="col-sm-6">
      <%= form.label :name, class: "field-label" %>
      <%= form.text_field :name, **pm_off(placeholder: "e.g. Dr. Alice Nguyen", class: [ "form-control", ("is-invalid" if care_team_member.errors[:name].any?) ]) %>
      <%= field_error care_team_member, :name %>
    </div>

    <div class="col-sm-6">
      <%= form.label :organization, class: "field-label" %>
      <%= form.text_field :organization, **pm_off(placeholder: "e.g. Banfield Pet Hospital", class: [ "form-control", ("is-invalid" if care_team_member.errors[:organization].any?) ]) %>
      <%= field_error care_team_member, :organization %>
    </div>

    <div class="col-sm-6">
      <%= form.label :phone, class: "field-label" %>
      <%= form.telephone_field :phone, **pm_off(class: [ "form-control", ("is-invalid" if care_team_member.errors[:phone].any?) ]) %>
      <%= field_error care_team_member, :phone %>
    </div>

    <div class="col-12">
      <%= form.label :email, class: "field-label" %>
      <%= form.email_field :email, **pm_off(class: [ "form-control", ("is-invalid" if care_team_member.errors[:email].any?) ]) %>
      <%= field_error care_team_member, :email %>
    </div>

    <div class="col-12">
      <%= form.label :notes, class: "field-label" %>
      <%= form.text_area :notes, rows: 3, **pm_off(class: [ "form-control", ("is-invalid" if care_team_member.errors[:notes].any?) ]) %>
      <%= field_error care_team_member, :notes %>
    </div>

  </div>

  <%# --- ACTIONS: Delete (edit only) on the left; Cancel + Save pushed right by ms-auto --- %>
  <div class="d-flex align-items-center mt-4">
    <% if care_team_member.persisted? %>
      <%= link_to confirm_delete_pet_care_team_member_path(pet, care_team_member), class: "btn btn-link text-danger text-decoration-none px-0 d-inline-flex align-items-center gap-1", data: { turbo_frame: "drawer" } do %>
        <i class="fa-regular fa-trash-can"></i>
        <span>Delete</span>
      <% end %>
    <% end %>

    <div class="d-flex gap-2 ms-auto">
      <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
      <%= form.submit "Save", class: "btn btn-ink rounded-pill px-4" %>
    </div>
  </div>

<% end %>
