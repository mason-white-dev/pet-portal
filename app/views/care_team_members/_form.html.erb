<%= form_with(model: [@pet, @care_team_member], class: "needs-validation") do |f| %>
  <%# --- ERROR MESSAGES (rendered only in the drawer frame) --- %>
  <% if care_team_member.errors.any? %>
    <div class="alert alert-danger p-3 mb-3" role="alert">
      <h6 class="alert-heading mb-1">Please fix the following</h6>
      <ul class="mb-0 small">
        <% care_team_member.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%# --- ROLE SELECT (dropdown) --- %>
  <div class="mb-3">
    <%= f.label :role, class: "form-label fw-bold" %>
    <%= f.select :role, CareTeamMember.roles.keys.map { |r| [r.titleize, r] }, {}, class: "form-select" %>
    <div class="form-text">Select the role for this care team member.</div>
  </div>
  <%# --- CONTACT NAME (text) --- %>
  <div class="mb-3">
    <%= f.label :contact_name, class: "form-label fw-bold" %>
    <%= f.text_field :contact_name, class: "form-control" %>
    <div class="form-text">Who should be contacted in this role?</div>
  </div>
  <%# --- NAME (text) --- %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-bold" %>
    <%= f.text_field :name, class: "form-control" %>
    <div class="form-text">The name of the care team member</div>
  </div>
  <%# --- PHONE (tel) --- %>
  <div class="mb-3">
    <%= f.label :phone, class: "form-label fw-bold" %>
    <%= f.text_field :phone, class: "form-control" %>
    <div class="form-text">Phone number (optional)</div>
  </div>
  <%# --- EMAIL (email) --- %>
  <div class="mb-3">
    <%= f.label :email, class: "form-label fw-bold" %>
    <%= f.email_field :email, class: "form-control" %>
    <div class="form-text">Email address (optional)</div>
  </div>
  <%# --- NOTES (rich text) --- %>
  <div class="mb-3">
    <%= f.label :notes, class: "form-label fw-bold" %>
    <%= f.text_area :notes, class: "form-control" %>
    <div class="form-text">Any notes about this team member (optional)</div>
  </div>
  <%# --- FOOTER WITH BUTTONS (same as edit.html.erb) --- %>
  <div class="modal-footer border-0 px-0 pb-0 d-flex justify-content-between">
    <%# Delete button shown only when editing an existing member; always hidden in the new form %>
    <% if care_team_member.persisted? %>
      <%= link_to confirm_delete_pet_care_team_member_path(@pet, @care_team_member), class: "btn btn-link text-danger text-decoration-none d-inline-flex align-items-center gap-1", data: { turbo_frame: "drawer" } do %>
        <i class="fa-regular fa-trash-can"></i>
        <span>Delete</span>
      <% end %>
    <% else %>
      <%# Spacer when new:pushes "Cancel" and "Save" together %>
      <div class="d-inline-flex"><!----></div>
    <% end %>
    <%# Cancel and save buttons %>
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
      <%= f.submit "Save", class: "btn btn-ink rounded-pill px-4 fw-medium" %>
    </div>
  </div>
<% end %>