<%#
  # Devise Registrations (Sign Up) View
  #
  # This view provides the user interface for creating a new account.
  # Key features:
  # - Wrapped in a Turbo Frame (`:auth_frame`) to allow seamless, SPA-like 
  #   navigation between the "Sign In" and "Create account" tabs without full page reloads.
  # - Renders standard Devise error messages and flash alerts.
  # - Includes a dummy "Name" input for layout purposes (needs backend wiring).
  #
  # Wire Frame Reference:
  # https://github.com/mason-white-dev/pet-portal/blob/main/wireframes/Landing%20page.png
%>
<%= turbo_frame_tag :auth_frame do %>
  <%# Tab Header Toggle (Sign Up Active) %>
  <div class="d-flex border rounded-pill p-1 bg-light mb-4" style="height: 50px;">
    <button class="btn btn-white rounded-pill fw-semibold w-50 shadow-sm border" type="button">Create account</button>
    <%= link_to "Sign in", new_user_session_path, class: "btn btn-link text-muted text-decoration-none fw-semibold w-50 d-flex align-items-center justify-content-center" %>
  </div>
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show py-2 small rounded-3" role="alert">
      <%= notice %>
      <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.75rem;"></button>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger alert-dismissible fade show py-2 small rounded-3" role="alert">
      <%= alert %>
      <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.75rem;"></button>
    </div>
  <% end %>

  <h2 class="h4 fw-bold mb-1">Start your pet's chart</h2>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { data: { turbo_frame: "_top" } }) do |f| %>
    <%# First Name Input %>
    <div class="mb-3">
      <%= f.label :first_name, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.text_field :first_name, autofocus: true, class: "form-control py-2 px-3 rounded border-secondary-subtle", placeholder: "John" %>
      <% if resource.errors[:first_name].any? %>
        <div class="text-danger small mt-1 fw-medium"><i class="fa-solid fa-circle-exclamation me-1"></i>First name <%= resource.errors[:first_name].join(", ") %></div>
      <% end %>
    </div>

    <%# Last Name Input %>
    <div class="mb-3">
      <%= f.label :last_name, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.text_field :last_name, class: "form-control py-2 px-3 rounded border-secondary-subtle", placeholder: "Smith" %>
      <% if resource.errors[:last_name].any? %>
        <div class="text-danger small mt-1 fw-medium"><i class="fa-solid fa-circle-exclamation me-1"></i>Last name <%= resource.errors[:last_name].join(", ") %></div>
      <% end %>
    </div>

    <%# Email Input %>
    <div class="mb-3">
      <%= f.label :email, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.email_field :email, autocomplete: "email", class: "form-control py-2 px-3 rounded border-secondary-subtle", placeholder: "you@email.com" %>
      <% if resource.errors[:email].any? %>
        <div class="text-danger small mt-1 fw-medium"><i class="fa-solid fa-circle-exclamation me-1"></i>Email <%= resource.errors[:email].join(", ") %></div>
      <% end %>
    </div>

    <%# Password Input %>
    <div class="mb-4">
      <%= f.label :password, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-control py-2 px-3 rounded border-secondary-subtle", placeholder: "••••••••" %>
      <% if resource.errors[:password].any? %>
        <div class="text-danger small mt-1 fw-medium"><i class="fa-solid fa-circle-exclamation me-1"></i>Password <%= resource.errors[:password].join(", ") %></div>
      <% end %>
    </div>

    <%# Submit Button %>
    <%= f.button "Create my account &rarr;".html_safe, type: :submit, class: "btn btn-dark w-100 py-3 rounded-pill fw-bold mb-4", style: "background-color: #1e1e1e;" %>
  <% end %>
<% end %>
