<%#
  # Devise Registrations (Sign Up) View
  #
  # This view provides the user interface for creating a new account.
  # Key features:
  # - Wrapped in a Turbo Frame (`:auth_frame`) to allow seamless, SPA-like
  #   navigation between the "Sign In" and "Create account" tabs without full page reloads.
  # - Renders inline, per-field validation errors below each input.
  # - Other sign-up feedback (flash) is rendered globally at the layout level.
  #
  # Wire Frame Reference:
  # wireframes/landing_page
%>
<%= turbo_frame_tag :auth_frame do %>
  <%#
    # Tab Header Toggle (Sign Up Active)
    #
    # The active tab ("Create account") is a plain, non-interactive button — it just
    # marks the page you're already on, so it has no action. The "Sign in" tab is a
    # link_to: clicking it loads the Sign In view INTO the surrounding `auth_frame`,
    # so only this form swaps out, not the whole page.
  %>
  <div class="d-flex border rounded-pill p-1 bg-light mb-4" style="height: 50px;">
    <%# --- Active tab: static label for the page we're on --- %>
    <button class="btn bg-white rounded-pill fw-semibold w-50 shadow-sm border" type="button">Create account</button>
    <%# --- Inactive tab: navigates to Sign In, swapping the auth_frame --- %>
    <%= link_to "Sign in", new_user_session_path, class: "btn btn-link text-muted text-decoration-none fw-semibold w-50 d-flex align-items-center justify-content-center" %>
  </div>
  <h2 class="h4 fw-bold mb-1">Start your pet's chart</h2>
  <%#
    # The form lives inside `auth_frame`, but `turbo_frame: "_top"` makes it submit
    # against the WHOLE page. That's deliberate: on success Devise redirects into
    # the app (the pets roster), and on failure it re-renders this view with errors —
    # both should take over the full page rather than get trapped inside this frame.
  %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { data: { turbo_frame: "_top" } }) do |f| %>
    <%#
      # --- Per-field validation display (the same pattern repeats for every field) ---
      #
      # When a field is invalid, two independent Bootstrap pieces light up:
      #
      #   1. `is-invalid` on the <input> itself (added conditionally in the class array).
      #      This draws the red border + red exclamation icon. It works no matter where
      #      the input sits in the DOM, because it's a class on the input directly.
      #
      #   2. A `.invalid-feedback` <div> below the input holds the readable message.
      #
      # Why the extra `d-block` on that <div>?
      #   Bootstrap ships `.invalid-feedback` as `display: none` and only un-hides it via
      #   a CSS rule that needs the input to be its direct SIBLING. But Rails wraps any
      #   errored field in a <div class="field_with_errors">, which nests the input one
      #   level down and breaks that sibling link — so the message would stay hidden.
      #
      #   We don't actually need Bootstrap's hide/reveal trick here: these errors are
      #   server-rendered, so we only output the <div> WHEN the field has an error (the
      #   `if` blocks below). `d-block` forces it visible, so "present in the HTML" just
      #   means "shown" — no client-side toggling required.
    %>

    <%# --- Email Input --- %>
    <div class="mb-3">
      <%= f.label :email, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: "you@email.com",
            class: [ "form-control py-2 px-3 rounded border-secondary-subtle", ("is-invalid" if resource.errors[:email].any?) ] %>
      <% if resource.errors[:email].any? %>
        <div class="invalid-feedback d-block"><i class="fa-solid fa-circle-exclamation me-1"></i>Email <%= resource.errors[:email].join(", ") %></div>
      <% end %>
    </div>

    <%# --- Password Input --- %>
    <div class="mb-4">
      <%= f.label :password, class: "form-label text-uppercase text-muted fw-bold small", style: "font-size: 0.75rem;" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
            class: [ "form-control py-2 px-3 rounded border-secondary-subtle", ("is-invalid" if resource.errors[:password].any?) ] %>
      <% if resource.errors[:password].any? %>
        <div class="invalid-feedback d-block"><i class="fa-solid fa-circle-exclamation me-1"></i>Password <%= resource.errors[:password].join(", ") %></div>
      <% end %>
    </div>

    <%# --- Submit Button --- %>
    <%= f.button "Create my account &rarr;".html_safe, class: "btn btn-dark w-100 py-3 rounded-pill fw-bold mb-4", style: "background-color: var(--pp-ink);" %>
  <% end %>
<% end %>
