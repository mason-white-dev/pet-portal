<%# 
  # Main Layout (Nested Layout)
  #
  # This layout is used for authenticated users browsing the main application.
  # It provides a standard dashboard structure:
  # - Left column: Fixed vertical navigation sidebar.
  # - Right column: Flexible content area for the specific view template.
  #
  # Wire Frame Reference:
  # https://github.com/mason-white-dev/pet-portal/blob/main/wireframes/Dashboard.png
%>

<% content_for :content do %>
  <div class="d-flex min-vh-100" style="background-color: #f6f5f1; color: #1e1e1e; font-family: system-ui, -apple-system, sans-serif;">
    
    <%# --- LEFT COLUMN (SIDEBAR NAV) --- %>
    <aside class="d-flex flex-column border-end px-3 py-4" style="width: 280px; flex-shrink: 0; border-color: rgba(0,0,0,0.1) !important;">
      
      <%# Logo %>
      <div class="d-flex align-items-center gap-2 mb-5 px-3">
        <i class="fa-solid fa-paw fs-4"></i>
        <span class="fs-4 fw-bold" style="font-family: 'Comic Sans MS', cursive, sans-serif; font-style: italic; letter-spacing: -0.5px;">Pet Portal</span>
      </div>

      <%# Navigation Links %>
      <nav class="nav flex-column gap-2 mb-auto px-1">
        <%# Dashboard (Active State) %>
        <a href="<%= root_path %>" class="nav-link d-flex align-items-center justify-content-between text-dark fw-medium rounded-pill bg-white border border-secondary-subtle px-3 py-2 shadow-sm">
          <div class="d-flex align-items-center gap-2">
            <span style="width: 6px; height: 6px; background-color: #e07a5f; border-radius: 50%;"></span>
            Dashboard
          </div>
          <span class="badge rounded-pill text-white" style="background-color: #e07a5f;">2</span>
        </a>

        <%# My Pets (Inactive State) %>
        <a href="#" class="nav-link d-flex align-items-center justify-content-between text-secondary fw-medium px-3 py-2">
          <div class="d-flex align-items-center gap-2">
            <span style="width: 6px; height: 6px; background-color: #adb5bd; border-radius: 50%;"></span>
            My pets
          </div>
        </a>
      </nav>

      <%# User Profile / Settings (Bottom) %>
      <div class="pt-4 mt-3 px-3" style="border-top: 1px dashed rgba(0,0,0,0.15);">
        <div class="d-flex align-items-center gap-3">
          <%# Avatar Circle %>
          <div class="rounded-circle border border-dark d-flex align-items-center justify-content-center bg-white" style="width: 38px; height: 38px; flex-shrink: 0;">
            <% if current_user&.first_name.present? %>
              <span class="fw-bold text-muted small"><%= current_user.first_name[0] %></span>
            <% else %>
              <i class="fa-solid fa-user text-muted small"></i>
            <% end %>
          </div>
          
          <%# Name and Settings Link %>
          <div class="lh-sm">
            <div class="fw-bold" style="font-size: 0.9rem;">
              <%= current_user&.first_name || "User" %> <%= current_user&.last_name&.first || "W" %>.
            </div>
            <%= link_to "Settings", edit_user_registration_path, class: "text-muted text-decoration-none small", style: "font-size: 0.75rem;" %>
          </div>
        </div>
      </div>
      
    </aside>

    <%# --- RIGHT COLUMN (MAIN CONTENT) --- %>
    <main class="flex-grow-1 p-4 p-md-5 overflow-auto">
      <%# Global Flash Messages %>
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show py-2 small rounded-3" role="alert">
          <%= notice %>
          <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.75rem;"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show py-2 small rounded-3" role="alert">
          <%= alert %>
          <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.75rem;"></button>
        </div>
      <% end %>

      <%# Injects the specific view (e.g. dashboard/index) %>
      <%= yield %>
    </main>
    
  </div>
<% end %>

<%# Inherit the base HTML structure from application.html.erb %>
<%= render template: "layouts/application" %>